<Page x:Class="DoctorMomFrontend.RegistrationClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DoctorMomFrontend"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="600"
      Title="Регистрация пациента">

    <Page.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#01579B"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#B3E5FC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0288D1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0277BD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0288D1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0288D1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E1F5FE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="#F0F8FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,20,10">
            <Button x:Name="BackButton" Content="← Назад" Style="{StaticResource SecondaryButtonStyle}" 
                    Padding="15,8" Margin="0,0,20,0"/>
            <TextBlock Text="➕ Новый пациент" FontSize="24" FontWeight="Bold" 
                       Foreground="#01579B" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,0">
            <Border Background="White" CornerRadius="10" Padding="25" 
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <!-- Фамилия -->
                    <TextBlock Text="Фамилия" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="SecondNameBox" Style="{StaticResource TextBoxStyle}"/>

                    <!-- Имя -->
                    <TextBlock Text="Имя" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="FirstNameBox" Style="{StaticResource TextBoxStyle}"/>

                    <!-- Телефон -->
                    <TextBlock Text="Телефон" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="PhoneNumberBox" Style="{StaticResource TextBoxStyle}"/>

                    <!-- Email -->
                    <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="EmailBox" Style="{StaticResource TextBoxStyle}"/>

                    <!-- Примечание -->
                    <TextBlock Text="Примечание" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="InfoBox" Style="{StaticResource TextBoxStyle}" 
                             Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,20">
            
            <Button x:Name="RegisterButton" Content="💾 Зарегистрировать" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Page>