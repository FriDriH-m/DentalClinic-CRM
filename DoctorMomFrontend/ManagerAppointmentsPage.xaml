<Page x:Class="DoctorMomFrontend.ManagerAppointmentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:DoctorMomFrontend"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Новая запись - DoctorMom">

    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#01579B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="BorderBrush" Value="#B3E5FC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#01579B"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="BorderBrush" Value="#B3E5FC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="BorderBrush" Value="#B3E5FC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0288D1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0277BD"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#B3E5FC"/>
                    <Setter Property="Foreground" Value="#777"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0288D1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0288D1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E1F5FE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StepCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="#F0F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="#0277BD" CornerRadius="0,20,20,0">
            <StackPanel Margin="20">
                <TextBlock Text="DoctorMom" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,30"/>
                <TextBlock Text="РАБОЧЕЕ МЕСТО" Foreground="#B3E5FC" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                <Button x:Name="AppointmentsPageButton" Content="📅 Записи на прием" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="ClientsPageButton" Content="👥 База пациентов" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="💳 Счета и оплата" Style="{StaticResource MenuButtonStyle}"/>

                <Separator Background="#26C6DA" Margin="0,20"/>
                <Button x:Name="LogoutButton" Content="Выход" Style="{StaticResource MenuButtonStyle}" Foreground="#FFAB91"/>
            </StackPanel>
        </Border>

        <!-- Основная область контента -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок страницы -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Button x:Name="BackButton" Content="← Назад" Style="{StaticResource SecondaryButtonStyle}" 
                        Padding="15,8" Margin="0,0,20,0"/>
                <TextBlock Text="➕ Новая запись" FontSize="26" FontWeight="Bold" 
                           Foreground="#01579B" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Форма добавления записи -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled" Margin="0,0,10,0">
                <StackPanel>
                    <!-- ШАГ 1: Выбор услуги -->
                    <Border Style="{StaticResource StepCardStyle}" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="1. Тип услуги" FontSize="18" FontWeight="Bold" 
                                       Foreground="#0277BD" Margin="0,0,0,15"/>

                            <TextBlock Text="Выберите услугу из списка" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox x:Name="ServiceComboBox" Style="{StaticResource FormComboBoxStyle}"
                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                      ItemsSource="{Binding Services}"/>

                            <Border Background="#E1F5FE" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="⏱ Длительность" FontWeight="SemiBold" 
                                                   Foreground="#01579B" FontSize="13"/>
                                        <TextBlock x:Name="ServiceDurationText" Text="—" FontSize="16" 
                                                   Foreground="#555" Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="💰 Стоимость" FontWeight="SemiBold" 
                                                   Foreground="#01579B" FontSize="13"/>
                                        <TextBlock x:Name="ServicePriceText" Text="— ₽" FontSize="16" 
                                                   Foreground="#0288D1" FontWeight="Bold" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="📝 Описание услуги" Style="{StaticResource FormLabelStyle}" Margin="0,15,0,8"/>
                            <Border Background="#F5F5F5" CornerRadius="6" Padding="10">
                                <TextBlock x:Name="ServiceDescriptionText" Text="Выберите услугу для отображения описания" 
                                           Foreground="#666" FontSize="13" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ШАГ 2: Дата, время и выбор врача -->
                    <Border Style="{StaticResource StepCardStyle}" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="2. Дата, время и врач" FontSize="18" FontWeight="Bold" 
                                       Foreground="#0277BD" Margin="0,0,0,15"/>

                            <!-- Дата и время -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="📅 Дата приема" Style="{StaticResource FormLabelStyle}"/>
                                    <DatePicker x:Name="DatePick" Style="{StaticResource FormDatePickerStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="Часы" Style="{StaticResource FormLabelStyle}"/>
                                    <ComboBox x:Name="HourComboBox" Style="{StaticResource FormComboBoxStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Минуты" Style="{StaticResource FormLabelStyle}"/>
                                    <ComboBox x:Name="MinuteComboBox" Style="{StaticResource FormComboBoxStyle}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Кнопка поиска врачей -->
                            <Button x:Name="FindDoctorsButton" Content="🔍 Найти свободных врачей" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Left" Margin="0,0,0,15"/>

                            <!-- Список свободных врачей -->
                            <ListBox x:Name="DoctorsListBox" 
                                     Height="150"
                                     BorderBrush="#B3E5FC" 
                                     BorderThickness="1" 
                                     Margin="0,0,0,10"
                                     SelectionMode="Single"
                                     Visibility="Collapsed">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#0288D1"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#B3E5FC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FullName}" 
                                                           FontWeight="SemiBold" 
                                                           Foreground="#01579B" 
                                                           FontSize="14"
                                                           Margin="0,0,15,0"/>

                                                <Border Background="#E3F2FD" 
                                                        CornerRadius="4" 
                                                        Padding="8,3"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Specialization}" 
                                                               Foreground="#0277BD" 
                                                               FontSize="12"
                                                               FontWeight="Medium"/>
                                                </Border>

                                                <Border Background="#4CAF50" 
                                                        CornerRadius="4" 
                                                        Padding="6,3"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsCertified, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    
                                                    <TextBlock Text="✓ Серт." 
                                                               Foreground="White" 
                                                               FontSize="10"
                                                               FontWeight="Medium"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="🕐" FontSize="14" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding Experience, StringFormat='{}{0} лет'}" 
                                                           Foreground="#666" 
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Сообщение если нет врачей -->
                            <TextBlock x:Name="NoDoctorsText" 
                                       Text="❌ Нет свободных врачей на это время" 
                                       Foreground="#E53935" 
                                       FontWeight="SemiBold" 
                                       Visibility="Collapsed" 
                                       Margin="0,5,0,0"
                                       TextAlignment="Center"/>

                            <!-- Выбранный врач -->
                            <Border x:Name="SelectedDoctorPanel" 
                                    Background="#E8F5E9" 
                                    CornerRadius="8" 
                                    Padding="12"
                                    BorderBrush="#81C784" 
                                    BorderThickness="1"
                                    Visibility="Collapsed"
                                    Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✅ Выбран: " FontWeight="SemiBold" Foreground="#2E7D32"/>
                                    <TextBlock x:Name="SelectedDoctorText" 
                                               Foreground="#2E7D32" 
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                </StackPanel>
                            </Border>

                            <Button x:Name="SelectDoctorButton" 
                                    Content="✓ Подтвердить выбор врача" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- ШАГ 3: Пациент -->
                    <Border Style="{StaticResource StepCardStyle}">
                        <StackPanel>
                            <TextBlock Text="3. Пациент" FontSize="18" FontWeight="Bold" 
                                       Foreground="#0277BD" Margin="0,0,0,15"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="0.8*"/>
                                    <ColumnDefinition Width="0.5*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="PatientSearchTextBox" 
                                         Style="{StaticResource FormTextBoxStyle}"
                                         Margin="0,0,10,0"/>

                                <Button x:Name="AddPatientButton" Grid.Column="1" 
                                        Content="+ Новый пациент" 
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,10,0"/>
                                <TextBlock x:Name="SpendBonusesButton" Grid.Column="2" 
                                        Text="Потратить бонусы" VerticalAlignment="Center"
                                        FontWeight="Bold" Foreground="#0277BD"/>
                                <CheckBox x:Name="UseBonusesCheckBox" 
                                          HorizontalAlignment="Center"
                                          Padding="10" 
                                          VerticalAlignment="Center" 
                                          Grid.Column="3"
                                          FontSize="16" Width="17">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.7" ScaleY="1.7"/>
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </Grid>

                            <DataGrid x:Name="PatientsDataGrid" 
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      Height="200"
                                      BorderBrush="#B3E5FC"
                                      BorderThickness="1"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F0F0F0"
                                      RowHeight="35"
                                      FontSize="13"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*"/>
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="1.3*"/>
                                    <DataGridTextColumn Header="Потрачено денег" Binding="{Binding MoneySpent}" Width="1*"/>
                                    <DataGridTextColumn Header="Бонусы" Binding="{Binding BonuseAmount}" Width="0.7*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border x:Name="ClientInfoPanel" Background="#E8F5E9" 
                                    CornerRadius="8" Padding="10" Margin="0,15,0,0" Visibility="Collapsed"
                                    BorderBrush="#81C784" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="ClientNameText" FontWeight="Bold" 
                                                   Foreground="#2E7D32" FontSize="15"/>
                                        <TextBlock x:Name="ClientPhoneText" Foreground="#555" FontSize="13" Margin="0,5,0,0"/>
                                        <TextBlock x:Name="ClientEmailText" Foreground="#555" FontSize="13" Margin="0,3,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="📋 Примечание:" FontWeight="SemiBold" 
                                                   Foreground="#2E7D32" FontSize="12"/>
                                        <TextBlock x:Name="ClientNotesText" Foreground="#666" 
                                                   FontSize="12" FontStyle="Italic" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Предварительный просмотр -->
                    <Border Background="#E8F5E9" CornerRadius="10" Padding="15" BorderBrush="#81C784" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="📋 Предварительный просмотр" FontSize="16" FontWeight="Bold" 
                                       Foreground="#2E7D32" Margin="0,0,0,10"/>
                            <TextBlock x:Name="PreviewText" Text="Заполните все поля для просмотра" 
                                       Foreground="#555" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки действий -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="SaveButton" Content="💾 Сохранить запись" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>