<Window x:Class="DoctorMomFrontend.RedactorMaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование материала" 
        Height="500" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поля формы -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,5" Padding="8"/>

                <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="DescriptionBox" Margin="0,0,0,5" Padding="8" 
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                <TextBlock Text="Количество (шт.)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="CountBox" Margin="0,0,0,5" Padding="8"/>

                <TextBlock Text="Закупочная цена (₽)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="PurchasePriceBox" Margin="0,0,0,5" Padding="8"/>

                <TextBlock Text="Розничная цена (₽)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="PriceBox" Margin="0,0,0,5" Padding="8"/>

                <CheckBox x:Name="CertifiedCheckBox" Content="Сертифицированный материал" 
                          Margin="0,0,0,5"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Отмена" Padding="15,8" Margin="0,0,10,0"
                   />
            <Button x:Name="SaveButton" Content="Сохранить" Padding="15,8" Background="#0288D1" 
                    Foreground="White" />
        </StackPanel>
    </Grid>
</Window>