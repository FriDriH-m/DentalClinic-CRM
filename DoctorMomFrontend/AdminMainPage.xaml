<Page x:Class="DoctorMomFrontend.AdminMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Панель Администратора">

    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#01579B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    <Grid Background="#F0F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0277BD" CornerRadius="0,20,20,0">
            <StackPanel Margin="20">
                <TextBlock Text="DoctorMom" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,30"/>

                <TextBlock Text="АДМИНИСТРИРОВАНИЕ" Foreground="#B3E5FC" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                <Button x:Name="EmployyesPageButton" Content="Сотрудники" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="ClinicsPageButton" Content="Филиалы" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="ServicesPageButton" Content="Услуги и склад" Style="{StaticResource MenuButtonStyle}"/>

                <Separator Background="#26C6DA" Margin="0,20"/>

                <Button x:Name="LogoutButton" Content="Выход" Style="{StaticResource MenuButtonStyle}" Foreground="#FFAB91"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,25">
                <TextBlock Text="Управление сотрудниками" FontSize="22" FontWeight="Bold" Foreground="#01579B"/>
                <Button x:Name ="AddEmployeeButton" Content="+ Добавить сотрудника" Margin="20,0,0,0" Padding="10,5" 
                        Background="#0288D1" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name ="GiveEmployeeAccessButton" Content="Выдать сертификат доктору" Margin="10,0,0,0" Padding="15,5" 
                        Background="#0288D1" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="15" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>

                <DataGrid x:Name="EmployeesGrid" AutoGenerateColumns="False" 
                          ItemsSource="{Binding Employees}"
                          CanUserAddRows="False" Background="White" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                          RowHeight="40" FontSize="14">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="2*"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding Specialization}" Width="*"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding DbUsername}" Width="*"/>
                        <DataGridTextColumn Header="Стаж" Binding="{Binding Experience}" Width="80"/>
                        <DataGridTemplateColumn Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Edit" Click="EditButton_Click"
                                                Foreground="#0288D1" Background="Transparent" 
                                                BorderThickness="0" Cursor="Hand"/>
                                        <Button Content="Del" Click="DeleteButton_Click"
                                                Foreground="#E53935" Background="Transparent" 
                                                BorderThickness="0" Cursor="Hand" Margin="5,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>

    
</Page>