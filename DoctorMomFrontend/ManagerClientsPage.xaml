<Page x:Class="DoctorMomFrontend.ManagerClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="База пациентов">
    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#01579B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="#F0F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню (идентичное) -->
        <Border Grid.Column="0" Background="#0277BD" CornerRadius="0,20,20,0">
            <StackPanel Margin="20">
                <TextBlock Text="DoctorMom" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,30"/>

                <TextBlock Text="РАБОЧЕЕ МЕСТО" Foreground="#B3E5FC" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                <Button x:Name="AppointmentsPageButton" Content="📅 Записи на прием" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="👥 База пациентов" Style="{StaticResource MenuButtonStyle}" Background="#01579B"/>
                

                <Separator Background="#26C6DA" Margin="0,20"/>

                <Button x:Name="LogoutButton" Content="Выход" Style="{StaticResource MenuButtonStyle}" Foreground="#FFAB91"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок и поиск -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="База пациентов" FontSize="26" FontWeight="Bold" Foreground="#01579B" VerticalAlignment="Center"/>

                <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="#B3E5FC" BorderThickness="2" Padding="5,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Column="0" VerticalAlignment="Center" BorderThickness="0" 
                                 FontSize="14" Padding="5" Text="Поиск пациента..."/>
                        <Button Grid.Column="1" Content="🔍" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Кнопки действий -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                <Button x:Name="NewClientButton" Content="+ Новый пациент" Padding="20,10" Background="#43A047" Foreground="White" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <!-- Таблица пациентов -->
            <Border Grid.Row="2" Background="White" CornerRadius="15" Padding="15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>

                <DataGrid x:Name="ClientsGrid" AutoGenerateColumns="False" 
                          CanUserAddRows="False" Background="White" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0"
                          RowHeight="40" FontSize="14" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="1.5*"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding PhoneNumber}" Width="1.3*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.7*"/>
                        <DataGridTextColumn Header="Потрачено" Binding="{Binding MoneySpent}" Width="1*"/>
                        <DataGridTextColumn Header="Бонусы" Binding="{Binding BonuseAmount}" Width="1*"/>

                        <DataGridTemplateColumn Header="Статус" Width="1.2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="5" Padding="5,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Активен">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Архив">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Новый">
                                                        <Setter Property="Background" Value="#E1F5FE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Активен">
                                                            <Setter Property="Foreground" Value="#43A047"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Архив">
                                                            <Setter Property="Foreground" Value="#E57373"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Новый">
                                                            <Setter Property="Foreground" Value="#0277BD"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏️" ToolTip="Редактировать" Click="RedactClient_Click"
                                                Foreground="#0288D1" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0"/>
                                        <Button Content="📋" ToolTip="История" Click="HistoryClient_Click"
                                                Foreground="#FF9800" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Page>