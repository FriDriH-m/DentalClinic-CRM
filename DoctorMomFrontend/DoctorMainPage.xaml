<Page x:Class="DoctorMomFrontend.DoctorMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DoctorMomFrontend"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Рабочее место Врача">

    <Page.Resources>
        <!-- Стиль меню -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#01579B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточки записи -->
        <Style x:Key="AppointmentCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#0288D1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопок действий -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3,0"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#0288D1"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0277BD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#43A047"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#388E3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Конвертер для статуса -->
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </Page.Resources>

    <Grid Background="#F0F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левое меню -->
        <Border Grid.Column="0" Background="#0277BD" CornerRadius="0,20,20,0">
            <StackPanel Margin="20">
                <TextBlock Text="DoctorMom" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,30"/>
                <TextBlock Text="КАБИНЕТ ВРАЧА" Foreground="#B3E5FC" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                <Button x:Name="ScheduleButton" Content="📅 Мое расписание" Style="{StaticResource MenuButtonStyle}" Background="#01579B"/>

                <Separator Background="#26C6DA" Margin="0,20"/>
                <Button x:Name="LogoutButton" Content="Выход" Style="{StaticResource MenuButtonStyle}" Foreground="#FFAB91"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Расписание на сегодня" FontSize="26" FontWeight="Bold" Foreground="#01579B" VerticalAlignment="Center"/>
                
            </Grid>

            <!-- Фильтры -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Фильтр:" VerticalAlignment="Center" FontSize="14" Foreground="#78909C" Margin="0,0,10,0"/>
                <RadioButton x:Name="FilterAll" Content="Все" IsChecked="True" 
                             Margin="0,0,15,0" VerticalAlignment="Center" 
                             GroupName="StatusFilter" Checked="StatusFilter_Checked"/>

                <RadioButton x:Name="FilterPending" Content="Ожидают" 
                             Margin="0,0,15,0" VerticalAlignment="Center" 
                             GroupName="StatusFilter" Checked="StatusFilter_Checked"/>

                <RadioButton x:Name="FilterCompleted" Content="Завершены" 
                             Margin="0,0,15,0" VerticalAlignment="Center" 
                             GroupName="StatusFilter" Checked="StatusFilter_Checked"/>

                <RadioButton x:Name="FilterCanceled" Content="Отменены" 
                             VerticalAlignment="Center" 
                             GroupName="StatusFilter" Checked="StatusFilter_Checked"/>
                <DatePicker x:Name="DateFilter" 
                            Margin="20,0,0,0" VerticalAlignment="Center" 
                            SelectedDateChanged="DateFilter_SelectedDateChanged"/>
            </StackPanel>

            <!-- Список записей -->
            <Border Grid.Row="2" Background="White" CornerRadius="15" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>

                <ListBox x:Name="AppointmentsListBox" 
                         Background="Transparent" 
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource AppointmentCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Время -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:HH:mm}'}" 
                                                   FontSize="20" FontWeight="Bold" Foreground="#0277BD"/>
                                        <TextBlock Text="{Binding Date, StringFormat='{}{0:dd.MM}'}" 
                                                   FontSize="12" Foreground="#90A4AE"/>
                                    </StackPanel>

                                    <!-- Информация -->
                                    <StackPanel Grid.Column="1" Margin="20,0">
                                        <TextBlock Text="{Binding ServiceName}" 
                                                   FontSize="14" Foreground="#78909C" Margin="0,5,0,0"/>
                                        <TextBlock Text="{Binding Status}" 
                                                   FontSize="12" FontWeight="SemiBold" 
                                                   Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <!-- Кнопки -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button x:Name="CloseButton" Content="✓ Закрыть" Style="{StaticResource SuccessButtonStyle}"
                                                Tag="{Binding}" Click="CloseAppointmentButton_Click"/>
                                        <Button x:Name="CancelButton" Content="✕ Отменить" Style="{StaticResource DangerButtonStyle}"
                                                Tag="{Binding}" Click="CancelAppointmentButton_Click"/>
                                        <Button x:Name="MaterialsButton" Content="📦 Материалы" Style="{StaticResource PrimaryButtonStyle}"
                                                Tag="{Binding}" Click="AppointmentMaterialsButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</Page>