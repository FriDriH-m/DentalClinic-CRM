<Window x:Class="DoctorMomFrontend.RedactorServiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DoctorMomFrontend"
        Title="Редактирование услуги" 
        Height="650" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Стиль для лейблов -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="#0277BD"/>
        </Style>

        <!-- Стиль для TextBox -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderBrush" Value="#B3E5FC"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поля формы -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Название -->
                <TextBlock Text="Название услуги" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="NameBox" Style="{StaticResource TextBoxStyle}"/>

                <!-- Описание -->
                <TextBlock Text="Описание" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="DescriptionBox" Style="{StaticResource TextBoxStyle}"
                         Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                <!-- Длительность и Цена в одну строку -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Длительность (мин)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="DurationBox" Style="{StaticResource TextBoxStyle}" 
                                 TextAlignment="Center" Margin="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Базовая цена (₽)" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="PriceBox" Style="{StaticResource TextBoxStyle}" 
                                 TextAlignment="Center" Margin="0"/>
                    </StackPanel>
                </Grid>

                <UniformGrid Columns="2" >
                    <!-- Категория -->
                    <StackPanel>
                        <TextBlock Text="Категория" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CategoryComboBox" 
                                  Padding="8" Margin="0,0,10,15"
                                  BorderBrush="#B3E5FC" Background="#FAFAFA"
                                  DisplayMemberPath="CategoryName" SelectedValuePath="CategoryId"/>
                    </StackPanel>
                    <StackPanel>
                        <!-- Клиника -->
                        <TextBlock Margin="10,0,0,5" Text="Клиника" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="ClinicComboBox" 
                                  Padding="8" Margin="10,0,0,0"
                                  BorderBrush="#B3E5FC" Background="#FAFAFA"
                                  DisplayMemberPath="Location" SelectedValuePath="Id"/>
                    </StackPanel>
                </UniformGrid>
                <Border x:Name="MaterialsBorder"
        Background="#E3F2FD" 
        CornerRadius="10" 
        Padding="15" 
        >
                    <StackPanel>
                        <TextBlock Text="Минимальные необходимые материалы" 
                   Foreground="#0277BD" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,15"/>

                        <!-- Поиск материала + Количество -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Название материала -->
                            <TextBox x:Name="MaterialSearchBox" 
                     Grid.Column="0" 
                     Padding="10,8" 
                     BorderBrush="#90CAF9" 
                     Background="White"
                     Margin="0,0,10,0"/>

                            <!-- Количество -->
                            <TextBlock Text="Кол-во" Grid.Column="1"
                                       VerticalAlignment="Center"></TextBlock>
                            <TextBox x:Name="MaterialQuantityBox" 
                                     Grid.Column="1" 
                                     Padding="10,8" 
                                     BorderBrush="#90CAF9" 
                                     Background="White"
                                     Margin="45,0,10,0"
                                     TextAlignment="Center"
                                     ToolTip="Количество материала"/>

                            <!-- Кнопка добавления -->
                            <Button x:Name="AddMaterialButton" 
                                    Grid.Column="2" 
                                    Content="➕ Добавить" 
                                    Background="#0288D1" 
                                    Foreground="White" 
                                    Padding="15,8"/>
                        </Grid>

                        <!-- Список выбранных материалов -->
                        <ListBox x:Name="MaterialsListBox" 
                                 Height="150" 
                                 BorderBrush="#90CAF9" 
                                 HorizontalContentAlignment="Stretch"
                                 Background="White" 
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding Name}" 
                                                   VerticalAlignment="Center" 
                                                   Foreground="#333"
                                   TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding Count}" 
                                                   VerticalAlignment="Center" 
                                                   Foreground="#333"
                                                   TextAlignment="Center"/>
                                        <Button Grid.Column="2" 
                                                Content="✕" 
                                                Padding="8,4" 
                                                Background="#EF5350" 
                                                Foreground="White"
                                                Click="RemoveMaterial_Click"
                                                Tag="{Binding}"
                                                ToolTip="Удалить материал"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </Border>


                <!-- Материалы -->
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Отмена" Padding="15,8" Margin="0,0,10,0"
                    />
            <Button x:Name="SaveButton" Content="Сохранить" Padding="15,8" Background="#0288D1"
                    Foreground="White" />
        </StackPanel>
    </Grid>
</Window>