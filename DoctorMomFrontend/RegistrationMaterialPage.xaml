<Page x:Class="DoctorMomFrontend.RegistrationMaterialPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DoctorMomFrontend"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1000"
      Title="Регистрация новой услуги">

    <Grid Background="#F0F8FF">

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Width="600" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Background="White" CornerRadius="15" Padding="30" Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.1" Color="Black"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Заголовок -->
                    <TextBlock Text="Добавление материала" FontSize="24" FontWeight="Bold" 
                               Foreground="#0277BD" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <!-- Название услуги -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Название материала" Foreground="#0277BD" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="MaterialNameBox" Padding="10,8" BorderBrush="#B3E5FC" 
                                 BorderThickness="1" Background="#FAFAFA"/>
                    </StackPanel>

                    <!-- Описание -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Описание" Foreground="#0277BD" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox x:Name="DescriptionBox" Padding="10,8" BorderBrush="#B3E5FC" 
                                 BorderThickness="1" Background="#FAFAFA" TextWrapping="Wrap" AcceptsReturn="True" Height="80"/>
                    </StackPanel>

                    <!-- Длительность и Цена в одну строку -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Цена закупки" Foreground="#0277BD" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="PurchasePriceBox" Padding="10,8" BorderBrush="#B3E5FC" 
                                     BorderThickness="1" Background="#FAFAFA" TextAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Базовая цена (₽)" Foreground="#0277BD" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="PriceBox" Padding="10,8" BorderBrush="#B3E5FC" 
                                     BorderThickness="1" Background="#FAFAFA" TextAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Сертифицированный" Foreground="#0277BD" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CertifiedComboBox" Padding="10,8" BorderBrush="#B3E5FC" 
                                      Background="#FAFAFA" SelectedValuePath="Tag">
                                <ComboBoxItem Content="Да" Tag="true"></ComboBoxItem>
                                <ComboBoxItem Content="Нет" Tag="false"></ComboBoxItem>
                            </ComboBox>

                        </StackPanel>
                    </Grid>
                    <UniformGrid Columns="2">
                        <!-- Категория -->
                        <StackPanel Margin="0,0,7.5,15">
                            <TextBlock Text="Количество" Foreground="#0277BD" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="CountTextBox" Padding="10,8" BorderBrush="#B3E5FC" 
                                      Background="#FAFAFA"/>
                        </StackPanel>

                        <!-- Клиника -->
                        <StackPanel Margin="7.5,0,0,0">
                            <TextBlock Text="Клиника" Foreground="#0277BD" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="ClinicComboBox" Padding="10,8" BorderBrush="#B3E5FC" 
                                      Background="#FAFAFA" DisplayMemberPath="Location" SelectedValuePath="Id"/>
                        </StackPanel>
                    </UniformGrid>
                    
                    <!-- Кнопка регистрации -->
                    <Button x:Name="RegisterMaterialButton" Content="ЗАРЕГИСТРИРОВАТЬ МАТЕРИАЛ" 
                            Margin="0,10,0,0" Background="#0288D1" Foreground="White" 
                            FontWeight="Bold" Padding="15,12" FontSize="14">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
        </ScrollViewer>
        <Button x:Name="BackButton" 
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Content="НАЗАД" Margin="15,15,0,0"
                    Background="#0288D1" Foreground="White" FontWeight="Bold" 
                    Padding="15,5" />
    </Grid>
</Page>