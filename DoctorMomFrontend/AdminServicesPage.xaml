<Page x:Class="DoctorMomFrontend.AdminServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="Панель Администратора">

    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#01579B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>
    <Grid Background="#F0F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>            
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0277BD" CornerRadius="0,20,20,0">
            <StackPanel Margin="20">
                <TextBlock Text="DoctorMom" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,30"/>

                <TextBlock Text="АДМИНИСТРИРОВАНИЕ" Foreground="#B3E5FC" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>

                <Button x:Name="EmployyesPageButton" Content="Сотрудники" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="ClinicsPageButton" Content="Филиалы" Style="{StaticResource MenuButtonStyle}"/>
                <Button x:Name="ServicesPageButton" Content="Услуги и склад" Style="{StaticResource MenuButtonStyle}"/>

                <Separator Background="#26C6DA" Margin="0,20"/>

                <Button x:Name="LogoutButton" Content="Выход" Style="{StaticResource MenuButtonStyle}" Foreground="#FFAB91"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,10">
                <TextBlock Text="Услуги клиник" FontSize="22" FontWeight="Bold" Foreground="#01579B"/>
                <Button x:Name ="AddServiceButton" Content="+ Добавить услугу" Margin="20,0,0,0" Padding="10,5" 
                        Background="#0288D1" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name ="OpenMaterialsPageButton" Content="Склад" Margin="10,0,0,0" Padding="15,5" 
                        Background="#0288D1" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,10">
                <StackPanel Margin="5,0,0,0">
                    <TextBlock TextAlignment="Center" Text="Клиника" Foreground="#0277BD" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ClinicComboBox"
                              Width="250"
                              Padding="0, 8"
                              BorderBrush="#B3E5FC"     
                              Margin="0,0,0,0"/>
                </StackPanel>
                <StackPanel Margin="5,0,0,0">
                    <TextBlock TextAlignment="Center" Text="Категория" Foreground="#0277BD" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CategoryComboBox"
                              Width="250"
                              Padding="0, 8"
                              BorderBrush="#B3E5FC"     
                              Margin="0,0,0,0"/>
                </StackPanel>
            </StackPanel>
            <ListBox x:Name="ServicesListBox"
                     Grid.Row="2" 
                     HorizontalAlignment="Stretch" 
                     Margin="0,0,0,0"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" 
                                   ItemWidth="600"
                                   ItemHeight="Auto"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" 
                                Padding="12" 
                                Margin="5" 
                                MaxWidth="700"
                                Background="#F8F9FA"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                SnapsToDevicePixels="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Cursor" Value="Arrow"/>
                                    <Style.Triggers>
                                        <!-- Эффект при наведении -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Setter Property="BorderBrush" Value="#2196F3"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Vertical">
                                <!-- Заголовок: Название услуги + Категория -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.7*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="14"
                                                   Foreground="#212121"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="200"/>
                                        <Border Background="#2196F3" 
                                                CornerRadius="4" 
                                                Padding="6,2" 
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CategoryName}" 
                                                       FontSize="10" 
                                                       Foreground="White"
                                                       FontWeight="Medium"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding ClinicAddress}" 
                                               FontSize="12" 
                                               Foreground="#666666"
                                               TextWrapping="Wrap"
                                               Margin="10,0"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="2">
                                        <Button x:Name="RedactServiceButton"
                                                Click="RedactServiceButton_Click"
                                                Content="Редактировать" 
                                                FontSize="11"
                                                Padding="5,2"
                                                Background="SkyBlue"
                                                Margin="0,0,0,10"
                                                Visibility="Visible">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                        <Button x:Name="DeleteServiceButton"
                                                Click="DeleteServiceButton_Click"
                                                Content="Удалить" 
                                                FontSize="11"
                                                Padding="5,2"
                                                Background="Red"
                                                Foreground="White"
                                                Margin="0"
                                                Visibility="Visible">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </StackPanel>
                                    
                                </Grid>
                                <!-- Описание услуги -->
                                <TextBlock Text="{Binding Description}" 
                                           FontSize="12" 
                                           Foreground="#666666"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"
                                           MaxHeight="40"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Разделитель -->
                                <Rectangle Height="1" 
                                           Fill="#E0E0E0" 
                                           Margin="0,4,0,8"/>
                                <!-- Нижняя строка: Длительность + Цена -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Длительность -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⏱" FontSize="14" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding DurationMinutes, StringFormat='{}{0} мин'}" 
                                       FontSize="12" 
                                       Foreground="#757575"/>
                                    </StackPanel>

                                    <!-- Цена -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding BasePrice, StringFormat='{}{0:0} ₽'}" 
                                       FontWeight="Bold" 
                                       FontSize="14" 
                                       Foreground="#2E7D32"/>
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <!-- Убираем стандартное выделение элемента -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Grid>
</Page>