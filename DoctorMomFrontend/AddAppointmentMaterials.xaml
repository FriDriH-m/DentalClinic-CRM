<Window x:Class="DoctorMomFrontend.AddAppointmentMaterials"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DoctorMomFrontend"
        Title="Редактирование услуги" 
        Height="370" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Стиль для лейблов -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Foreground" Value="#0277BD"/>
        </Style>

        <!-- Стиль для TextBox -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="BorderBrush" Value="#B3E5FC"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поля формы -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border x:Name="MaterialsBorder"
                        Background="#E3F2FD" 
                        CornerRadius="10" 
                        Padding="15">
                    <StackPanel>
                        <TextBlock Text="Использованные материалы" 
                                   Foreground="#0277BD" 
                                   FontWeight="SemiBold" 
                                   FontSize="16" 
                                   Margin="0,0,0,15"/>
                        <!-- Поиск материала + Количество -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Название материала -->
                            <TextBox x:Name="MaterialSearchBox" 
                                     Grid.Column="0" 
                                     Padding="10,8" 
                                     BorderBrush="#90CAF9" 
                                     Background="White"
                                     Margin="0,0,10,0"/>
                            <!-- Количество -->
                            <TextBlock Text="Кол-во" Grid.Column="1"
                                       VerticalAlignment="Center"></TextBlock>
                            <TextBox x:Name="MaterialQuantityBox" 
                                     Grid.Column="1" 
                                     Padding="10,8" 
                                     BorderBrush="#90CAF9" 
                                     Background="White"
                                     Margin="45,0,10,0"
                                     TextAlignment="Center"
                                     ToolTip="Количество материала"/>

                            <!-- Кнопка добавления -->
                            <Button x:Name="AddMaterialButton" 
                                    Grid.Column="2" 
                                    Content="➕ Добавить" 
                                    Background="#0288D1" 
                                    Foreground="White" 
                                    Padding="15,8"/>
                        </Grid>

                        <!-- Список выбранных материалов -->
                        <ListBox x:Name="MaterialsListBox" 
                                 Height="150" 
                                 BorderBrush="#90CAF9" 
                                 HorizontalContentAlignment="Stretch"
                                 Background="White" 
                                 SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding Name}" 
                                                   VerticalAlignment="Center" 
                                                   Foreground="#333"
                                   TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding Count}" 
                                                   VerticalAlignment="Center" 
                                                   Foreground="#333"
                                                   TextAlignment="Center"/>
                                        <Button Grid.Column="2" 
                                                Content="✕" 
                                                Padding="8,4" 
                                                Background="#EF5350" 
                                                Foreground="White"
                                                Click="RemoveMaterial_Click"
                                                Tag="{Binding}"
                                                ToolTip="Удалить материал"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="{x:Type ListBoxItem}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Отмена" Padding="15,8" Margin="0,0,10,0"
                    />
            <Button x:Name="SaveButton" Content="Сохранить" Padding="15,8" Background="#0288D1"
                    Foreground="White" />
        </StackPanel>
    </Grid>
</Window>