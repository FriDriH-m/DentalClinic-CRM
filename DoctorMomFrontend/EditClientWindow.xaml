<Window x:Class="DoctorMomFrontend.EditClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        mc:Ignorable="d" 
        d:DesignHeight="650" d:DesignWidth="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Title="Редактирование пациента">

    <Window.Resources>
        <!-- Стиль для текстовых полей -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="CaretBrush" Value="#0277BD"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для заголовков полей -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#01579B"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#F0F8FF" CornerRadius="15">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.15"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок окна -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="👤" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Редактирование пациента" FontSize="22" FontWeight="Bold" Foreground="#01579B"/>
                        <TextBlock x:Name="ClientNameText" Text="" FontSize="13" Foreground="#90A4AE" Margin="0,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" x:Name="CloseButton" Content="✕" 
                        Background="Transparent" BorderThickness="0" 
                        Foreground="#90A4AE" FontSize="18" 
                        Width="35" Height="35" Cursor="Hand"
                        VerticalAlignment="Top">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Setter Property="Foreground" Value="#E57373"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Форма редактирования -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Имя -->
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Имя"/>
                    <TextBox x:Name="FirstNameBox" Style="{StaticResource InputTextBoxStyle}" 
                             Margin="0,0,0,10" TextWrapping="NoWrap"/>

                    <!-- Фамилия -->
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Фамилия"/>
                    <TextBox x:Name="SecondNameBox" Style="{StaticResource InputTextBoxStyle}" 
                             Margin="0,0,0,10" TextWrapping="NoWrap"/>

                    <!-- Телефон -->
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Телефон"/>
                    <TextBox x:Name="PhoneBox" Style="{StaticResource InputTextBoxStyle}" 
                             Margin="0,0,0,10" TextWrapping="NoWrap">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SaveCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Email -->
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Email"/>
                    <TextBox x:Name="EmailBox" Style="{StaticResource InputTextBoxStyle}" 
                             Margin="0,0,0,10" TextWrapping="NoWrap"/>

                    <!-- Дополнительная информация -->
                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Дополнительная информация"/>
                    <Border Background="#F5F5F5" CornerRadius="8" Padding="0">
                        <TextBox x:Name="InfoBox" Style="{StaticResource InputTextBoxStyle}" 
                                 TextWrapping="Wrap" AcceptsReturn="True" 
                                 MinHeight="100" VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки действий -->
            <Grid Grid.Row="2" Margin="0,25,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" x:Name="CancelButton" Content="Отмена" 
                        Background="#9E9E9E" Style="{StaticResource ActionButtonStyle}" 
                        Margin="0,0,15,0"/>

                <Button Grid.Column="2" x:Name="SaveButton" Content="💾 Сохранить" 
                        Background="#0288D1" Style="{StaticResource ActionButtonStyle}"/>
            </Grid>
        </Grid>
    </Border>
</Window>